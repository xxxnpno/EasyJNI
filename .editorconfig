# EditorConfig — applies to every contributor's editor without extra setup.
# https://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,yml,yaml,json}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{cmd,bat}]
end_of_line = crlf

# Visual Studio project files use CRLF
[*.{vcxproj,vcxproj.filters,sln,slnx,props,targets}]
end_of_line = crlf
